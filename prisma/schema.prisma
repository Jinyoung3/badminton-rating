generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String @id @default(cuid())
  clerkId            String @unique
  email              String @unique
  name               String
  userNumber         Int    @unique @default(autoincrement())
  sex                String
  location           String
  preferredGameType  String
  winCount           Int    @default(0)
  lossCount          Int    @default(0)
  rating             Int    @default(0) // Legacy/display; use ratingSingles/ratingDoubles
  ratingMu           Float  @default(1500)
  ratingPhi          Float  @default(350)
  ratingSigma        Float  @default(0.06)
  // Singles rating and record
  ratingSingles      Int    @default(1500)
  ratingMuSingles    Float  @default(1500)
  ratingPhiSingles   Float  @default(350)
  ratingSigmaSingles Float  @default(0.06)
  winCountSingles    Int    @default(0)
  lossCountSingles   Int    @default(0)
  // Doubles rating and record
  ratingDoubles      Int    @default(1500)
  ratingMuDoubles    Float  @default(1500)
  ratingPhiDoubles   Float  @default(350)
  ratingSigmaDoubles Float  @default(0.06)
  winCountDoubles    Int    @default(0)
  lossCountDoubles   Int    @default(0)

  createdEvents           Event[]                  @relation("EventCreator")
  eventParticipants       EventParticipant[]
  createdMatches          Match[]                  @relation("MatchCreator")
  matchesAsPlayer1        Match[]                  @relation("Player1")
  matchesAsPlayer2        Match[]                  @relation("Player2")
  matchesAsPlayer3        Match[]                  @relation("Player3")
  matchesAsPlayer4        Match[]                  @relation("Player4")
  scoreCorrectionRequests ScoreCorrectionRequest[]
  selfRating              SelfRating?
  organizationId          String?
  organization            Organization?            @relation(fields: [organizationId], references: [id])
}

model SelfRating {
  id        String   @id @default(cuid())
  userId    String   @unique
  question1 Int
  question2 Int
  question3 Int
  question4 Int
  question5 Int
  question6 Int
  question7 Int
  question8 Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
  members   User[]
}

model Event {
  id                      String                   @id @default(cuid())
  name                    String
  description             String?
  location                String
  date                    DateTime
  eventCode               String?                  @unique
  organizationId          String
  creatorId               String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  creator                 User                     @relation("EventCreator", fields: [creatorId], references: [id])
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participants            EventParticipant[]
  matches                 Match[]
  scoreCorrectionRequests ScoreCorrectionRequest[]
}

model EventParticipant {
  id       String   @id @default(cuid())
  eventId  String
  userId   String
  isAbsent Boolean  @default(false)
  joinedAt DateTime @default(now())
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model ScoreCorrectionRequest {
  id            String   @id @default(cuid())
  matchId       String
  eventId       String?
  requesterId   String
  reason        String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  proposedGames Json?
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  requester     User     @relation(fields: [requesterId], references: [id])
}

model Match {
  id                      String                   @id @default(cuid())
  type                    String
  gameType                String
  eventId                 String?
  creatorId               String
  player1Id               String
  player2Id               String
  player3Id               String?
  player4Id               String?
  games                   Json
  winner                  String
  matchDate               DateTime                 @default(now())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  creator                 User                     @relation("MatchCreator", fields: [creatorId], references: [id])
  event                   Event?                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player1                 User                     @relation("Player1", fields: [player1Id], references: [id])
  player2                 User                     @relation("Player2", fields: [player2Id], references: [id])
  player3                 User?                    @relation("Player3", fields: [player3Id], references: [id])
  player4                 User?                    @relation("Player4", fields: [player4Id], references: [id])
  scoreCorrectionRequests ScoreCorrectionRequest[]
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}
